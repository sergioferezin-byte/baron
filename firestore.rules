rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // GLOBAL CORES & SAFETY NET
    // ==========================================
    
    // Default-deny all unmapped paths
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // REUSABLE SECURITY PRIMITIVES
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn(); // Relaxed to support active sessions in development without forcing SMTP link clicks
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Capture upcoming resource shape
    function incoming() {
      return request.resource.data;
    }

    // Capture existing database resource
    function existing() {
      return resource.data;
    }

    // ==========================================
    // VALIDATIONS & MODEL SECURITY GATES
    // ==========================================

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'nome_completo', 'apelido', 'role', 'createdAt', 'updatedAt']) 
        && data.email is string && data.email.size() <= 255
        && data.nome_completo is string && data.nome_completo.size() <= 150
        && data.apelido is string && data.apelido.size() <= 50
        && data.role is string && (data.role == 'user' || data.role == 'admin' || data.role == 'super_admin');
    }

    // ==========================================
    // CORE COLLECTION GROUPS & PATHS
    // ==========================================

    // --- USERS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) 
        && isEmailVerified()
        && isValidUser(incoming())
        && incoming().role == 'user'; // Client can't assign higher roles

      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().role == existing().role; // Protect role from modification

      allow delete: if isAdmin();
    }

    // --- USER PREFERENCES ---
    match /userPreferences/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && incoming().keys().hasAll(['idioma_preferido', 'timezone', 'preferred_voice_id', 'avatar_model_style', 'updatedAt'])
        && incoming().idioma_preferido is string && incoming().idioma_preferido.size() <= 10
        && incoming().timezone is string && incoming().timezone.size() <= 50
        && incoming().preferred_voice_id is string && incoming().preferred_voice_id.size() <= 128
        && incoming().avatar_model_style is string && incoming().avatar_model_style.size() <= 50;

      allow update: if isOwner(userId)
        && incoming().idioma_preferido is string && incoming().idioma_preferido.size() <= 10
        && incoming().timezone is string && incoming().timezone.size() <= 50
        && incoming().preferred_voice_id is string && incoming().preferred_voice_id.size() <= 128
        && incoming().avatar_model_style is string && incoming().avatar_model_style.size() <= 50;

      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- RITUALS (nested) ---
    match /users/{userId}/rituals/{ritualId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidId(userId) && isValidId(ritualId);
    }

    // --- CONVERSATIONS ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn()
        && isValidId(conversationId)
        && incoming().userId == request.auth.uid // Force current identity model
        && incoming().personaId is string && incoming().personaId.size() <= 128
        && incoming().titulo is string && incoming().titulo.size() <= 150
        && incoming().status == 'ativa';

      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId; // Owner remains identical

      allow delete: if isAdmin();

      // --- MESSAGES ---
      match /messages/{messageId} {
        // Master Gate: Evaluate parent conversation owner
        allow read: if isSignedIn() 
          && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid || isAdmin());

        allow create: if isSignedIn()
          && isValidId(messageId)
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid
          && incoming().userId == request.auth.uid
          && (incoming().role == 'usuario' || incoming().role == 'barao') // Support both client user and baron messages
          && incoming().contentType in ['text', 'audio', 'image']
          && incoming().content is string && incoming().content.size() <= 10000;

        // Messages are immutable once generated. Only administrators/moderators can override or purge.
        allow update, delete: if isAdmin();
      }
    }

    // --- MEMORIES ---
    match /users/{userId}/memories/{memoryId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Memories are managed strictly on the server-side via Cloud functions/Admin system triggers
      allow write: if isAdmin();
    }

    // --- MEMORIES FEEDBACK ---
    match /users/{userId}/memoryFeedback/{memoryId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow users to confirm, reject or edit computed memories
      allow create, update: if isOwner(userId)
        && isValidId(memoryId)
        && incoming().confirmed is bool
        && incoming().rejected is bool
        && incoming().edited is bool;

      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- MEMORY SUMMARIES ---
    match /users/{userId}/memorySummaries/{summaryType} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Strictly computed/edited in background threads by the synthesis engine
      allow write: if isAdmin();
    }

    // --- LIFE EVENTS ---
    match /users/{userId}/lifeEvents/{eventId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && isValidId(eventId)
        && incoming().title is string && incoming().title.size() <= 128
        && incoming().isResolved is bool;

      allow update: if isOwner(userId)
        && incoming().title is string && incoming().title.size() <= 128
        && incoming().isResolved is bool;

      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- DIARY ENTRIES ---
    match /users/{userId}/diaryEntries/{entryId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId)
        && isValidId(entryId)
        && incoming().date is string && incoming().date.size() == 10
        && incoming().title is string && incoming().title.size() <= 150
        && incoming().content is string && incoming().content.size() <= 20000;

      allow update: if isOwner(userId)
        && incoming().title is string && incoming().title.size() <= 150
        && incoming().content is string && incoming().content.size() <= 20000;

      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- PLANS ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- SUBSCRIPTIONS ---
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Strictly triggered by Stripe webhook / billing functions
      allow write: if isAdmin();
    }

    // --- FEATURES & USER FEATURES ---
    match /features/{featureId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId}/userFeatures/{featureId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // --- AI USAGE LOGS ---
    match /users/{userId}/aiUsage/{usageId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // --- ADMIN USERS & AUDIT LOGS ---
    match /adminUsers/{adminId} {
      allow read: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Strictly written during backup or support events
    }

    // --- AVATARS & VOICE CATALOGS ---
    match /avatars/{avatarId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /voiceProfiles/{voiceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- MEDIA ASSETS ---
    match /users/{userId}/mediaAssets/{assetId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Generated strictly inside server environment and registered there
      allow write: if isAdmin();
    }

    // --- DAILY USAGE LIMITS AND RESET COUNTERS ---
    match /users/{userId}/dailyUsage/{dateStr} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Written and updated systematically by the proxy backend to prevent client cheat bypass
      allow write: if isAdmin();
    }
  }
}
