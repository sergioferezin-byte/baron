# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# ADMIN_PASSWORD: Opcional. Senha customizada de acesso ao painel de administração (/admin).
# Se não preenchida, o valor padrão de segurança é 'barao123'.
ADMIN_PASSWORD=

# FIREBASE CONFIGURATION (Vite Client-side)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=meubarao-b049c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=meubarao-b049c
VITE_FIREBASE_STORAGE_BUCKET=meubarao-b049c.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VITE_FIREBASE_FIRESTORE_DATABASE_ID: Required only if your Cloud Firestore instance is a
# named database instead of the "(default)" one (check Firebase Console > Firestore Database
# > the database picker at the top). Leave empty to use "(default)".
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
