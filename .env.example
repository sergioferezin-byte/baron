# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# DEEPSEEK_API_KEY: OBRIGATÓRIA para o chat principal (O Barão conversa via DeepSeek).
# Crie em https://platform.deepseek.com > API Keys. Os demais recursos (diário,
# crônicas, músicas, meditação) continuam usando a GEMINI_API_KEY.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL: Opcional. Padrão: deepseek-chat (use deepseek-reasoner para respostas mais elaboradas e caras).
DEEPSEEK_MODEL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# ADMIN_PASSWORD: Opcional. Senha customizada de acesso ao painel de administração (/admin).
# Se não preenchida, o valor padrão de segurança é 'barao123'.
ADMIN_PASSWORD=

# SUPABASE CONFIGURATION
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: Supabase > Project Settings > API
# SUPABASE_SERVICE_ROLE_KEY: OBRIGATÓRIA no servidor para criar usuários no
# Supabase Auth (Authentication). Sem ela, cadastro/login via Supabase falham.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DATABASE (preferido): connection string do Postgres do Supabase.
# Supabase > Project Settings > Database > Connection string (Session pooler).
# Ex.: postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
# Defina DATABASE_SSL=false apenas para Postgres local sem TLS.
DATABASE_SSL=

# LEGACY: variáveis discretas (Cloud SQL). Usadas somente se DATABASE_URL estiver vazia.
SQL_HOST=
SQL_PORT=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=
SQL_SSL=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

