# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# DEEPSEEK_API_KEY: OBRIGATÓRIA para o chat principal (O Barão conversa via DeepSeek).
# Crie em https://platform.deepseek.com > API Keys. Os demais recursos (diário,
# crônicas, músicas, meditação) continuam usando a GEMINI_API_KEY.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL: Opcional. Padrão: deepseek-chat (use deepseek-reasoner para respostas mais elaboradas e caras).
DEEPSEEK_MODEL=

# KIE_API_KEY: Chave do kie.ai (https://kie.ai > API Key). Habilita a voz
# realista do Barão (ElevenLabs TTS). Sem ela, o app usa a voz do navegador.
KIE_API_KEY=
# KIE_TTS_VOICE: Opcional. ID da voz ElevenLabs no kie.ai.
# Padrão: 6F5Zhi321D3Oq7v1oNT4 (Hank — narrador profundo e envolvente).
KIE_TTS_VOICE=
# KIE_TTS_MODEL: Opcional. Padrão: elevenlabs/text-to-speech-turbo-2-5
# (metade do preço do multilingual-v2, mesmas vozes). Para qualidade máxima,
# use elevenlabs/text-to-speech-multilingual-v2.
KIE_TTS_MODEL=

# BARAO_REFERENCE_IMAGE_URL: Opcional. URL pública do retrato oficial do
# Barão usado como referência de rosto nas imagens do Álbum.
BARAO_REFERENCE_IMAGE_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# ADMIN_PASSWORD: Opcional. Senha customizada de acesso ao painel de administração (/admin).
# Se não preenchida, o valor padrão de segurança é 'barao123'.
ADMIN_PASSWORD=

# SUPABASE CONFIGURATION
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: Supabase > Project Settings > API
# SUPABASE_SERVICE_ROLE_KEY: OBRIGATÓRIA no servidor para criar usuários no
# Supabase Auth (Authentication). Sem ela, cadastro/login via Supabase falham.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DATABASE (preferido): connection string do Postgres do Supabase.
# Supabase > Project Settings > Database > Connection string (Session pooler).
# Ex.: postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
# Defina DATABASE_SSL=false apenas para Postgres local sem TLS.
DATABASE_SSL=

# LEGACY: variáveis discretas (Cloud SQL). Usadas somente se DATABASE_URL estiver vazia.
SQL_HOST=
SQL_PORT=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=
SQL_SSL=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

