{
  "entities": {
    "User": {
      "title": "User",
      "description": "Fundamental user data associated directly with Firebase Auth UID",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "nome_completo": {
          "type": "string",
          "description": "Full name of the user"
        },
        "apelido": {
          "type": "string",
          "description": "Nickname used by the AI to address the user"
        },
        "data_nascimento": {
          "type": "string",
          "format": "date",
          "description": "Birthdate of the user"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin", "super_admin"],
          "description": "Access control role of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account registration timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last profile update timestamp"
        }
      },
      "required": ["email", "nome_completo", "apelido", "role", "createdAt", "updatedAt"]
    },
    "UserPreferences": {
      "title": "UserPreferences",
      "description": "Explicit UI, language, and behavior preferences for the user",
      "type": "object",
      "properties": {
        "idioma_preferido": {
          "type": "string",
          "description": "Locale preference, e.g. pt-BR"
        },
        "fatos_biografia": {
          "type": "string",
          "description": "Extended biographic background details provided explicitly"
        },
        "genero_afetor": {
          "type": "string",
          "description": "Preferred gender and style of interaction"
        },
        "timezone": {
          "type": "string",
          "description": "Timezone identifier, e.g. America/Sao_Paulo"
        },
        "preferred_voice_id": {
          "type": "string",
          "description": "Document ID referring to global voiceProfiles selection"
        },
        "avatar_model_style": {
          "type": "string",
          "description": "Style configuration for future avatar renderings"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last preference adjustment"
        }
      },
      "required": ["idioma_preferido", "timezone", "preferred_voice_id", "avatar_model_style", "updatedAt"]
    },
    "Ritual": {
      "title": "Ritual",
      "description": "Configured daily habits/emotional checkpoints the user runs on a scheduled basis",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Name of the routine/ritual"
        },
        "description": {
          "type": "string",
          "description": "Prompt explanation of the ritual"
        },
        "scheduledTime": {
          "type": "string",
          "description": "Time of day in HH:MM format"
        },
        "frequency": {
          "type": "string",
          "enum": ["daily", "weekly", "custom"],
          "description": "Recurrence pattern of the ritual"
        },
        "isActive": {
          "type": "boolean",
          "description": "Status indicator"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Ritual creation timestamp"
        }
      },
      "required": ["title", "scheduledTime", "frequency", "isActive", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "High-level interactive chat sessions between the user and the Barão",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference UID of the owner user"
        },
        "personaId": {
          "type": "string",
          "description": "The personality archetype ID used"
        },
        "titulo": {
          "type": "string",
          "description": "Client visible or AI summary name for the dialogue thread"
        },
        "status": {
          "type": "string",
          "enum": ["ativa", "arquivada", "concluida"],
          "description": "Current interactive state of the conversation"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Dialogue creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last message timestamp"
        }
      },
      "required": ["userId", "personaId", "titulo", "status", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual messages in a continuous conversation chain",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the participant"
        },
        "role": {
          "type": "string",
          "enum": ["usuario", "barao"],
          "description": "Sender indicator"
        },
        "content": {
          "type": "string",
          "description": "Textual context of the message"
        },
        "contentType": {
          "type": "string",
          "enum": ["text", "audio", "image"],
          "description": "Mode of content payload"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Precise creation timestamp"
        },
        "aiModel": {
          "type": "string",
          "description": "Model tag if synthesized, null if sent by user"
        },
        "tokenInput": {
          "type": "integer",
          "description": "Input tokens calculated for processing"
        },
        "tokenOutput": {
          "type": "integer",
          "description": "Response tokens spawned"
        },
        "cost": {
          "type": "number",
          "description": "Financial cost estimation of this transaction"
        },
        "memoryExtractionStatus": {
          "type": "string",
          "enum": ["pending", "processed", "skipped"],
          "description": "Indicates whether the memory extraction worker analysed this message"
        }
      },
      "required": ["userId", "role", "content", "contentType", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Isolated high-resolution cognitive memory entities extracted by the AI pipeline",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Owner userId"
        },
        "category": {
          "type": "string",
          "enum": ["fact", "emotion", "preference", "desire", "belief", "goal", "fear", "trauma", "boundary", "fantasy", "life_event", "relationship_pattern", "emotional_pattern"],
          "description": "Core psychological category classification of the memory entry"
        },
        "summary": {
          "type": "string",
          "description": "Condensed synthesis of the cognitive fact"
        },
        "originalFragment": {
          "type": "string",
          "description": "The exact source quote or fragment from dialogue which matches this deduction"
        },
        "sourceType": {
          "type": "string",
          "enum": ["chat", "direct_biography", "ritual"],
          "description": "Original source channel"
        },
        "sourceId": {
          "type": "string",
          "description": "Document ID reference of the source message/ritual"
        },
        "importanceScore": {
          "type": "number",
          "description": "Evaluation of severity or importance. Range: 0.0 - 1.0"
        },
        "confidenceScore": {
          "type": "number",
          "description": "AI extractor confidence level. Range: 0.0 - 1.0"
        },
        "emotionalWeight": {
          "type": "number",
          "description": "Affective loading assigned. Range: -1.0 to +1.0"
        },
        "isActive": {
          "type": "boolean",
          "description": "Toggle to invalidate memory nodes manually"
        },
        "isSensitive": {
          "type": "boolean",
          "description": "Denotes extreme trauma or high-privacy memories requiring strict isolated prompts"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Storage timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update or activation timestamp"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "Expiry timestamp for short-lived cognitive state contexts"
        },
        "lastReinforcedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when memory was validated or referenced in dialogue"
        }
      },
      "required": ["userId", "category", "summary", "originalFragment", "sourceType", "importanceScore", "confidenceScore", "isActive", "isSensitive", "createdAt", "updatedAt", "lastReinforcedAt"]
    },
    "MemoryFeedback": {
      "title": "MemoryFeedback",
      "description": "Explicit validations, denials, or adjustments made directly by the user on extracted memories",
      "type": "object",
      "properties": {
        "confirmed": {
          "type": "boolean",
          "description": "Indicates user verified this memory"
        },
        "rejected": {
          "type": "boolean",
          "description": "Clear rejection request to delete or soft-delete this node"
        },
        "edited": {
          "type": "boolean",
          "description": "Specifies user manually corrected the memory profile"
        },
        "feedbackText": {
          "type": "string",
          "description": "Optional textual notes corrected by the user"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of feedback entry"
        }
      },
      "required": ["confirmed", "rejected", "edited", "updatedAt"]
    },
    "MemorySummary": {
      "title": "MemorySummary",
      "description": "Consolidated psychological summaries by time window for fast prompt feeding",
      "type": "object",
      "properties": {
        "summaryType": {
          "type": "string",
          "enum": ["daily", "weekly", "monthly", "coreIdentity"],
          "description": "Scope of the summarizing window"
        },
        "content": {
          "type": "string",
          "description": "Synthesized text explaining character growth, emotional state, or issues"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Synthesis timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last modification stamp"
        }
      },
      "required": ["summaryType", "content", "createdAt", "updatedAt"]
    },
    "LifeEvent": {
      "title": "LifeEvent",
      "description": "Milestone events in database profile mapping key life elements",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title, e.g. Divórcio, Mudança de Emprego, Luto"
        },
        "description": {
          "type": "string",
          "description": "Details regarding the event"
        },
        "eventDate": {
          "type": "string",
          "format": "date",
          "description": "Approximate date of the occurrence"
        },
        "emotionalImpact": {
          "type": "string",
          "description": "Perceived intensity or nature of the impact"
        },
        "isResolved": {
          "type": "boolean",
          "description": "Indicates if user has worked through this event emotionally"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time added to system"
        }
      },
      "required": ["title", "eventDate", "isResolved", "createdAt"]
    },
    "DiaryEntry": {
      "title": "DiaryEntry",
      "description": "Daily emotional or poetic entries created explicitly or compiled organically by the AI",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Reference date YYYY-MM-DD"
        },
        "title": {
          "type": "string",
          "description": "Aesthetic title"
        },
        "content": {
          "type": "string",
          "description": "Poetic narrative synthesis"
        },
        "humorConsolidado": {
          "type": "string",
          "description": "Affective/emotional tone identified"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["date", "title", "content", "humorConsolidado", "createdAt"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Global definitions of available tiers and business configurations",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the tier"
        },
        "slug": {
          "type": "string",
          "enum": ["free", "premium", "elite"],
          "description": "Unique key identifier"
        },
        "description": {
          "type": "string",
          "description": "Summarized tier benefits"
        },
        "price": {
          "type": "number",
          "description": "Subscription cost per month"
        },
        "maxDailyMessages": {
          "type": "integer",
          "description": "Rate-limiting threshold. Free = 15"
        },
        "hasPersistentMemory": {
          "type": "boolean",
          "description": "Unlocks RAG long-term storage features"
        },
        "allowedMediaTypes": {
          "type": "array",
          "description": "Permitted media modalities (text, audio, image, etc.)"
        }
      },
      "required": ["name", "slug", "description", "price", "maxDailyMessages", "hasPersistentMemory"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription statuses synchronized with payment gateway triggers",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of subscriber"
        },
        "plano_atual": {
          "type": "string",
          "enum": ["free", "premium", "elite"],
          "description": "Active tier identifier"
        },
        "status": {
          "type": "string",
          "enum": ["active", "canceled", "incomplete", "past_due"],
          "description": "Active payment gateway status"
        },
        "stripe_subscription_id": {
          "type": "string",
          "description": "ID map from payment processors"
        },
        "data_inicio": {
          "type": "string",
          "format": "date-time",
          "description": "Period start timestamp"
        },
        "data_fim": {
          "type": "string",
          "format": "date-time",
          "description": "Expiry or renewal date"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Synchronisation timestamp"
        }
      },
      "required": ["userId", "plano_atual", "status", "data_inicio", "updatedAt"]
    },
    "Feature": {
      "title": "Feature",
      "description": "Definitions mapping system keys to specific authorization scopes",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human label"
        },
        "key": {
          "type": "string",
          "description": "The target key used in coding permissions"
        },
        "description": {
          "type": "string",
          "description": "Feature documentation"
        },
        "planLevels": {
          "type": "array",
          "description": "Tiers granted with explicit access"
        }
      },
      "required": ["name", "key", "planLevels"]
    },
    "UserFeature": {
      "title": "UserFeature",
      "description": "Individual locks, beta triggers, or exceptions allocated to specific users",
      "type": "object",
      "properties": {
        "featureKey": {
          "type": "string",
          "description": "Key mapped directly to standard features"
        },
        "isOverrideActive": {
          "type": "boolean",
          "description": "If true, overrides basic plan rules for this feature"
        },
        "grantedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Granting stamp"
        }
      },
      "required": ["featureKey", "isOverrideActive", "grantedAt"]
    },
    "AIUsage": {
      "title": "AIUsage",
      "description": "Strict billing and resource observation logging logs",
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "Short signature of the prompt category"
        },
        "tokensConsumed": {
          "type": "integer",
          "description": "Sum of total tokens processed"
        },
        "estimatedCost": {
          "type": "number",
          "description": "Relative infrastructure cost standard"
        },
        "type": {
          "type": "string",
          "enum": ["text", "voice", "image", "music"],
          "description": "Modality type consumed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Execution timestamp"
        }
      },
      "required": ["prompt", "tokensConsumed", "type", "createdAt"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Roles registry used in cloud security rules to authenticate admin commands",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Validated admin email"
        },
        "role": {
          "type": "string",
          "enum": ["super_admin", "admin", "support"],
          "description": "Assigned support / operator authority"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Validation timestamp"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Write-only immutable security ledger detailing back-office modifications",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Target profile affected"
        },
        "actorEmail": {
          "type": "string",
          "format": "email",
          "description": "Email of support agent executing the transaction"
        },
        "action": {
          "type": "string",
          "description": "Action stamp, eg. MEMORIES_PURGED"
        },
        "details": {
          "type": "string",
          "description": "Text description of intent or reference specs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Audit creation timestamp"
        }
      },
      "required": ["userId", "actorEmail", "action", "createdAt"]
    },
    "Avatar": {
      "title": "Avatar",
      "description": "Catalog properties defining visual models",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Avatar design name"
        },
        "style": {
          "type": "string",
          "description": "Art rendering style tag"
        },
        "imageUrl": {
          "type": "string",
          "description": "Storage resource pointer"
        },
        "isPro": {
          "type": "boolean",
          "description": "Tier restriction flag"
        }
      },
      "required": ["name", "style", "imageUrl", "isPro"]
    },
    "VoiceProfile": {
      "title": "VoiceProfile",
      "description": "Catalog properties specifying speaker synthesizer options",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "System name of synthetic persona"
        },
        "gender": {
          "type": "string",
          "description": "Vocal style signature"
        },
        "voiceEngine": {
          "type": "string",
          "description": "Model framework tag"
        },
        "isPro": {
          "type": "boolean",
          "description": "Specifies Elite/Premium tier requirements"
        }
      },
      "required": ["name", "gender", "voiceEngine", "isPro"]
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "description": "Pointers matching files in Cloud Storage to user assets",
      "type": "object",
      "properties": {
        "assetType": {
          "type": "string",
          "enum": ["image", "audio", "music"],
          "description": "Raw media type classification"
        },
        "storagePath": {
          "type": "string",
          "description": "Internal Google Cloud Storage URI gs://..."
        },
        "downloadUrl": {
          "type": "string",
          "description": "Secure signed download URL"
        },
        "promptUsed": {
          "type": "string",
          "description": "The exact model prompt string used to compose this asset"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Assembly timestamp"
        }
      },
      "required": ["assetType", "storagePath", "downloadUrl", "createdAt"]
    },
    "DailyUsage": {
      "title": "DailyUsage",
      "description": "O(1) calendar document updated incrementally on active requests to maintain rate limits",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Calendar signature in YYYY-MM-DD"
        },
        "messagesSent": {
          "type": "integer",
          "description": "Total queries in calendar day"
        },
        "imagesGenerated": {
          "type": "integer",
          "description": "Total image creations in calendar day"
        },
        "audiosGenerated": {
          "type": "integer",
          "description": "Total synth voice generations in calendar day"
        },
        "musicsGenerated": {
          "type": "integer",
          "description": "Total music synthesizer requests in calendar day"
        },
        "estimatedCost": {
          "type": "number",
          "description": "Aggregated daily model cost"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last incremental event"
        }
      },
      "required": ["date", "messagesSent", "imagesGenerated", "audiosGenerated", "musicsGenerated", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user collection mapped to UID"
    },
    "/userPreferences/{userId}": {
      "schema": "UserPreferences",
      "description": "Separate root collection for 1-to-1 preferences of users"
    },
    "/users/{userId}/rituals/{ritualId}": {
      "schema": "Ritual",
      "description": "Personal daily checkpoints and routines"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Conversations list referencing users and persona types"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual dialog items nested inside conversations"
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Extracted memories used during core prompts (RAG pipeline)"
    },
    "/users/{userId}/memoryFeedback/{memoryId}": {
      "schema": "MemoryFeedback",
      "description": "Actions and corrections targeting active memories"
    },
    "/users/{userId}/memorySummaries/{summaryType}": {
      "schema": "MemorySummary",
      "description": "Consolidated temporary insights mapping temporal spaces"
    },
    "/users/{userId}/lifeEvents/{eventId}": {
      "schema": "LifeEvent",
      "description": "Key milestone moments for psychological context mapping"
    },
    "/users/{userId}/diaryEntries/{entryId}": {
      "schema": "DiaryEntry",
      "description": "Emotional and therapeutic journals written poetically"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Global definitions of service tiers and limits configurations"
    },
    "/subscriptions/{userId}": {
      "schema": "Subscription",
      "description": "Core subscription levels synced via webhooks"
    },
    "/features/{featureId}": {
      "schema": "Feature",
      "description": "Master catalog of functional features and permissions mapping"
    },
    "/users/{userId}/userFeatures/{featureId}": {
      "schema": "UserFeature",
      "description": "Isolated beta permissions or plan overrides"
    },
    "/users/{userId}/aiUsage/{usageId}": {
      "schema": "AIUsage",
      "description": "Detailed monitoring parameters of model invocations"
    },
    "/adminUsers/{adminId}": {
      "schema": "AdminUser",
      "description": "Operator permissions records for support and control channels"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative write-only activity ledger"
    },
    "/avatars/{avatarId}": {
      "schema": "Avatar",
      "description": "Global library of system avatars"
    },
    "/voiceProfiles/{voiceId}": {
      "schema": "VoiceProfile",
      "description": "Global library of synthesized voice models"
    },
    "/users/{userId}/mediaAssets/{assetId}": {
      "schema": "MediaAsset",
      "description": "Database registers pointing directly to media resources in Cloud Storage"
    },
    "/users/{userId}/dailyUsage/{dateStr}": {
      "schema": "DailyUsage",
      "description": "Date-based counter tracking and rate-limiting document"
    }
  }
}
